<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net6.0</TargetFramework>
        <RootNamespace>projectilemultipier</RootNamespace>
        <Configurations>Debug;Release</Configurations>
        <Nullable>enable</Nullable>
        <AssemblyName>projectilemultipier</AssemblyName>
        <LangVersion>preview</LangVersion>
        <Optimize>False</Optimize>
        <DebugType>embedded</DebugType>
    </PropertyGroup>

    <ItemGroup>
        <!-- Reference the local paths to the DLL files -->
        <Reference Include="ModHelper" HintPath="path/to/ModHelper.dll" />
        <Reference Include="HarmonyLib" HintPath="path/to/HarmonyLib.dll" />
    </ItemGroup>

    <ItemGroup>
        <Content Include=".github\workflows\build.yml" />
    </ItemGroup>

    <Import Project="..\btd6.targets" />
</Project>
